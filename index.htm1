<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>Мое приложение</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            background: var(--tg-theme-bg-color, #ffffff);
            color: var(--tg-theme-text-color, #000000);
            padding: 20px;
            min-height: 100vh;
        }

        .container {
            max-width: 400px;
            margin: 0 auto;
        }

        h1 {
            font-size: 24px;
            margin-bottom: 20px;
            text-align: center;
            color: var(--tg-theme-header-color, #000000);
        }

        .card {
            background: var(--tg-theme-secondary-bg-color, #f5f5f5);
            border-radius: 16px;
            padding: 20px;
            margin-bottom: 20px;
        }

        .button {
            background: var(--tg-theme-button-color, #2481cc);
            color: var(--tg-theme-button-text-color, #ffffff);
            border: none;
            padding: 12px 24px;
            border-radius: 10px;
            font-size: 16px;
            font-weight: 500;
            width: 100%;
            cursor: pointer;
            transition: opacity 0.2s;
        }

        .button:hover {
            opacity: 0.9;
        }

        .input {
            width: 100%;
            padding: 12px;
            border: 1px solid var(--tg-theme-hint-color, #ccc);
            border-radius: 10px;
            background: var(--tg-theme-bg-color, #ffffff);
            color: var(--tg-theme-text-color, #000000);
            margin-bottom: 15px;
            font-size: 16px;
        }

        .user-info {
            background: var(--tg-theme-bg-color, #ffffff);
            border-radius: 12px;
            padding: 15px;
            margin-bottom: 20px;
            border: 1px solid var(--tg-theme-hint-color, #e0e0e0);
        }

        .user-info p {
            margin: 8px 0;
        }

        .back-button {
            background: transparent;
            border: 1px solid var(--tg-theme-button-color, #2481cc);
            color: var(--tg-theme-button-color, #2481cc);
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>🚀 Мое Mini App</h1>

        <div class="user-info" id="userInfo">
            <p>👤 Загрузка данных пользователя...</p>
        </div>

        <div class="card">
            <h3>📝 Пример формы</h3>
            <input type="text" class="input" id="userInput" placeholder="Введите что-нибудь...">
            <button class="button" id="submitBtn">Отправить</button>
        </div>

        <div class="card">
            <h3>⚡ Действия</h3>
            <button class="button" id="closeBtn">Закрыть приложение</button>
            <button class="button back-button" id="backBtn" style="margin-top: 10px;">← Назад в бот</button>
        </div>
    </div>

    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <script>
        // Инициализация Telegram WebApp
        const tg = window.Telegram.WebApp;
        
        // Расширяем приложение на весь экран
        tg.expand();
        
        // Показываем кнопку "Назад" если нужно
        tg.BackButton.show();
        
        // Обработчик кнопки "Назад" в Telegram
        tg.BackButton.onClick(() => {
            tg.close();
        });
        
        // Получаем данные пользователя
        const user = tg.initDataUnsafe?.user;
        const userInfoDiv = document.getElementById('userInfo');
        
        if (user) {
            userInfoDiv.innerHTML = `
                <p>👤 <strong>${user.first_name || ''} ${user.last_name || ''}</strong></p>
                <p>🆔 ID: ${user.id}</p>
                ${user.username ? `<p>📱 @${user.username}</p>` : ''}
                <p>🌐 Язык: ${user.language_code || 'ru'}</p>
            `;
        } else {
            userInfoDiv.innerHTML = `<p>👤 Гость (данные не переданы)</p>`;
        }
        
        // Отправка данных в бот
        document.getElementById('submitBtn').addEventListener('click', () => {
            const inputValue = document.getElementById('userInput').value;
            if (inputValue.trim()) {
                // Отправляем данные обратно в бот
                tg.sendData(JSON.stringify({
                    action: 'user_input',
                    value: inputValue,
                    timestamp: new Date().toISOString()
                }));
                
                // Показываем уведомление
                tg.showAlert(`Отправлено: ${inputValue}`);
                
                // Очищаем поле
                document.getElementById('userInput').value = '';
            } else {
                tg.showAlert('Пожалуйста, введите текст');
            }
        });
        
        // Закрытие приложения
        document.getElementById('closeBtn').addEventListener('click', () => {
            tg.close();
        });
        
        // Кнопка "Назад"
        document.getElementById('backBtn').addEventListener('click', () => {
            tg.close();
        });
        
        // Настройка главной кнопки (опционально)
        tg.MainButton.setText('Готово');
        tg.MainButton.onClick(() => {
            tg.sendData(JSON.stringify({ action: 'main_button_clicked' }));
            tg.MainButton.hide();
        });
        
        // Показываем MainButton через 2 секунды
        setTimeout(() => {
            tg.MainButton.show();
        }, 2000);
        
        // Сообщаем, что приложение готово
        tg.ready();
    </script>
</body>
</html>